{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "folderTrust": {
      "enabled": true
    }
  },
  "general": {
    "defaultApprovalMode": "plan",
    "enableNotifications": true,
    "checkpointing": {
      "enabled": true
    },
    "plan": {
      "enabled": true,
      "modelRouting": true
    },
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d"
    }
  },
  "context": {
    "loadMemoryFromIncludeDirectories": false,
    "fileFiltering": {
      "respectGitIgnore": true,
      "respectGeminiIgnore": true,
      "enableRecursiveFileSearch": true,
      "enableFuzzySearch": true
    }
  },
  "tools": {
    "useRipgrep": true,
    "disableLLMCorrection": true
  },
  "ui": {
    "compactToolOutput": true,
    "showLineNumbers": true
  },
  "experimental": {
    "worktrees": true,
    "modelSteering": true
  },
  "skills": {
    "enabled": true
  },
  "hooksConfig": {
    "enabled": true,
    "notifications": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "name": "memories-session-start",
            "type": "command",
            "command": "bash {{HOME}}/.gemini/hooks/memories-session.sh start gemini",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "name": "memories-session-end",
            "type": "command",
            "command": "bash {{HOME}}/.gemini/hooks/memories-session.sh stop gemini",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "memories": {
      "command": "memories",
      "args": ["serve"]
    }
  }
}
