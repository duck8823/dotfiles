{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "60",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "500000",
    "BASH_MAX_OUTPUT_LENGTH": "12000"
  },
  "permissions": {
    "allow": [
      "Bash(claude -p:*)",
      "Bash(claude --print:*)",
      "Bash(codex exec:*)",
      "Bash(agy --print:*)",
      "Bash(ai-review --pr:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmux claude-hook session-start 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmux claude-hook stop 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/stop-self-review.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/stop-work-guard.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmux claude-hook notification 2>/dev/null || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmux claude-hook prompt-submit 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/check-gh-commands.sh"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/check-permissions.sh"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/check-verify-before-push.sh"
          },
          {
            "type": "command",
            "command": "if command -v rtk >/dev/null 2>&1; then rtk hook claude; else bash {{HOME}}/.claude/hooks/check-codex-worktree.sh; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/record-verify-stamp.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/post-edit-lint.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/post-write-format.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmux claude-hook post-tool-use-failure 2>/dev/null || true"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmux claude-hook subagent-stop 2>/dev/null || true"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmux claude-hook stop-failure 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmux claude-hook session-end 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": false,
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": false,
    "swift-lsp@claude-plugins-official": false,
    "playwright@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": false,
    "atlassian@claude-plugins-official": false,
    "slack@claude-plugins-official": false,
    "hookify@claude-plugins-official": false,
    "playground@claude-plugins-official": false,
    "firebase@claude-plugins-official": false,
    "discord@claude-plugins-official": false,
    "notion-workspace-plugin@notion-plugin-marketplace": false,
    "traceary@traceary-plugins": true
  },
  "extraKnownMarketplaces": {
    "traceary-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/duck8823/traceary.git"
      }
    }
  }
}
