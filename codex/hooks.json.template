{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.codex/hooks/memories-session.sh start",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.codex/hooks/memories-session.sh stop",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
