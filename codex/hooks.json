{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/memories-session.sh start codex",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.claude/hooks/memories-session.sh stop codex",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
